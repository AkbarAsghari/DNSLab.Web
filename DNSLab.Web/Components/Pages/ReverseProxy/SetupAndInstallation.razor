@attribute [Route(AllRoutes.SetupAndInstallation)]
<SeoProvider Title="DNSLab cli" />

<MudText Typo="Typo.h1" Align="Align.Center">
    DNSLab CLI
</MudText>

<MudText Typo="Typo.body1"
         Align="Align.Center"
         Class="mt-2 mb-10">
    سریع‌ترین راه برای انتشار سرویس‌های محلی روی اینترنت
</MudText>

<MudPaper Class="pa-10" Outlined>

    <MudText Typo="Typo.h4" Class="mb-4">
        1. نصب DNSLab CLI
    </MudText>

    <MudStack Row Class="mb-4">
        <BaseButton Class="px-7"
                    StartIcon="@DNSLabIcons.Windows"
                    Size="Size.Small"
                    Color="@(_SelectedOs == OS.Windows ? Color.Primary : Color.Default)"
                    Variant="@(_SelectedOs == OS.Windows ? Variant.Filled : Variant.Outlined)"
                    OnClick="()=> ChangeOS(OS.Windows)">
            Windows
        </BaseButton>

        <BaseButton Class="px-10"
                    StartIcon="@DNSLabIcons.Linux"
                    Size="Size.Small"
                    Color="@(_SelectedOs == OS.Linux ? Color.Primary : Color.Default)"
                    Variant="@(_SelectedOs == OS.Linux ? Variant.Filled : Variant.Outlined)"
                    OnClick="()=> ChangeOS(OS.Linux)">
            Linux
        </BaseButton>
    </MudStack>

    @switch (_SelectedOs)
    {
        case OS.Windows:

            <MudStack Row>
                <BaseButton Size="Size.Small"
                            EndIcon="@DNSLabIcons.Download"
                            Color="Color.Primary"
                            Variant="Variant.Filled"
                            DropShadow="false"
                            Href="https://cdn.dnslab.link/dnslab-windows-amd64.exe">
                    دانلود نسخه Windows x64
                </BaseButton>

                <BaseButton Size="Size.Small"
                            EndIcon="@DNSLabIcons.Download"
                            Color="Color.Primary"
                            Variant="Variant.Filled"
                            DropShadow="false"
                            Href="https://cdn.dnslab.link/dnslab-windows-arm64.exe">
                    دانلود نسخه Windows ARM64
                </BaseButton>
            </MudStack>

            break;

        case OS.Linux:

            <CodeSnippet Language="bash"
                         Code="curl -fsSL https://cdn.dnslab.link/linux/install.sh | sudo sh" />

            break;
    }

    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h4" Class="mb-2">
        2. احراز هویت
    </MudText>

    <MudText Class="mb-4">
        این دستور را فقط یک بار اجرا کنید:
    </MudText>

    <CodeSnippet Language="bash"
                 Code="@($"token set {_Token}")" />

    <MudAlert Severity="Severity.Success"
              Class="mt-4"
              ContentAlignment="HorizontalAlignment.Start">
        توکن شما در تنظیمات CLI ذخیره خواهد شد و نیازی به تکرار این مرحله نیست.
    </MudAlert>

    @if (_IsMobileApproved is not null && _IsMobileApproved == false)
    {
        <MudAlert Severity="Severity.Warning"
                  Class="mt-4"
                  ContentAlignment="HorizontalAlignment.Start">
            برای استفاده از DNSLab ابتدا شماره همراه خود را تأیید کنید.
        </MudAlert>
    }

    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h4" Class="mb-4">
        3. ایجاد تونل
    </MudText>

    <MudGrid>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Outlined>
                <MudText Typo="Typo.h6">HTTP</MudText>
                <MudText Typo="Typo.body2">
                    وب‌سایت، API و Webhook
                </MudText>

                <BaseButton Href="@AllRoutes.HttpReverseProxy"
                            Class="mt-3"
                            Size="Size.Small"
                            Variant="Variant.Filled"
                            Color="Color.Primary">
                    مشاهده آموزش
                </BaseButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Outlined>
                <MudText Typo="Typo.h6">TCP</MudText>
                <MudText Typo="Typo.body2">
                    SSH، RDP، FTP و دیتابیس‌ها
                </MudText>

                <BaseButton Href="@AllRoutes.TcpReverseProxy"
                            Class="mt-3"
                            Size="Size.Small"
                            Variant="Variant.Filled"
                            Color="Color.Primary">
                    مشاهده آموزش
                </BaseButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Outlined>
                <MudText Typo="Typo.h6">UDP</MudText>
                <MudText Typo="Typo.body2">
                    DNS، بازی آنلاین و VoIP
                </MudText>

                <BaseButton Href="@AllRoutes.UdpReverseProxy"
                            Class="mt-3"
                            Size="Size.Small"
                            Variant="Variant.Filled"
                            Color="Color.Primary">
                    مشاهده آموزش
                </BaseButton>
            </MudPaper>
        </MudItem>

    </MudGrid>

</MudPaper>