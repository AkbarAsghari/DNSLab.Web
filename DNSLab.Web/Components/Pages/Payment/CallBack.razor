@attribute [Route(AllRoutes.CallBackPayment)]
@attribute [Authorize]
<SeoProvider Title="نتیجه پرداخت" />

<MudText Typo="Typo.h1" Align="Align.Center">نتیجه پرداخت</MudText>
<MudText Class="mt-5 mb-10" Align="Align.Center">وضعیت نهایی ترانکش شما به شرح زیر میباشد</MudText>

<MudCard Elevation="0">
    <MudCardHeader>
        <CardHeaderContent></CardHeaderContent>
        <CardHeaderActions>
            <MudButton EndIcon="@DNSLabIcons.Back" Variant="Variant.Filled" Color="Color.Primary" Size="MudBlazor.Size.Small" Href="@AllRoutes.MyWallet">بازگشت</MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @if (IsVerified == null)
        {
            <MudStack AlignItems="AlignItems.Center">
                <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate />
            </MudStack>
        }
        else
        {
            <MudAlert ContentAlignment="HorizontalAlignment.Start" NoIcon Severity="@(IsVerified == true ? Severity.Success : Severity.Warning)">
                @if (IsVerified == true)
                {
                    <MudText Class="mb-1">کیف پول شما شارژ شد!</MudText>
                    <MudText Typo="Typo.body2">هر تومنی که به این سایت واریز شود، انرژی و دلگرمی تازه‌ای برای ساختن امکانات بهتر به ما می‌دهد.</MudText>
                    <MudText Typo="Typo.body2">خوشحالیم که کنارتان هستیم.</MudText>
                }
                else
                {
                    <MudText Class="mb-1">شارژ کیف پول نا موفق بود!</MudText>
                    <MudText Typo="Typo.body2">توضیحات : @Result</MudText>
                }
            </MudAlert>
        }
    </MudCardContent>
</MudCard>