@page "/"

<SeoProvider Title="DNSLab | DDNS و Reverse Proxy برای سرورهای خانگی"
             Meta_Description="بدون IP ثابت، سرور خانگی، دوربین امنیتی یا پروژه خود را در ۵ دقیقه آنلاین کنید. سرویس DDNS و Reverse Proxy امن و سریع" />

<!-- Hero Section with Gradient -->
<MudText Typo="Typo.h1" Align="Align.Center" Class="mt-8 mb-3 font-weight-bold">
    سرویس‌های محلی خود را بدون IP ثابت روی اینترنت منتشر کنید.
</MudText>
<MudText Typo="Typo.h5" Align="Align.Center" Class="mb-8 mt-4">با DDNS و Reverse Proxy، بدون Port Forwarding و دردسرهای NAT، در کمتر از یک دقیقه سرویس‌های خود را از هر جای دنیا در دسترس قرار دهید.</MudText>

<!-- CTA -->
<MudStack Class="pa-5 my-6">
    <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
        <BaseButton Variant="Variant.Filled"
                    Color="Color.Primary"
                    Size="Size.Large"
                    Href="@AllRoutes.SetupAndInstallation">
            رایگان شروع کنید 🚀
        </BaseButton>
    </MudStack>
</MudStack>

<!-- Why Choose Us -->
<MudText Typo="Typo.h3" Align="Align.Center" Class="mt-16 mb-8 font-weight-bold">چرا DNSLab ؟</MudText>
<MudGrid Spacing="6" Justify="Justify.Center" Class="mb-16">
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg h-100" Outlined>
            <MudIcon Icon="@DNSLabIcons.Security" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">
                امنیت بالا
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                ارتباطات رمزنگاری‌شده و دسترسی امن به سرویس‌های شما بدون نیاز به باز کردن پورت‌های غیرضروری.
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg h-100" Outlined>
            <MudIcon Icon="@DNSLabIcons.Speed" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">
                سرعت و پایداری
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                اتصال سریع و پایدار با کمترین تأخیر برای استفاده روزمره و سرویس‌های حساس.
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg h-100" Outlined>
            <MudIcon Icon="@DNSLabIcons.Protocols" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">
                پشتیبانی از چندین پروتکل
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                پشتیبانی از HTTP، TCP و UDP برای انواع سرویس‌ها و برنامه‌ها.
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg h-100" Outlined>
            <MudIcon Icon="@DNSLabIcons.Router" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">
                سازگار با تجهیزات مختلف
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                قابل استفاده روی MikroTik، OpenWrt، Linux، Windows، Docker و Raspberry Pi.
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg h-100" Outlined>
            <MudIcon Icon="@DNSLabIcons.Cloud" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">
                بدون نیاز به IP ثابت
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                حتی با اینترنت خانگی و IP متغیر نیز سرویس‌های شما همیشه در دسترس خواهند بود.
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg h-100" Outlined>
            <MudIcon Icon="@DNSLabIcons.Tools" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">
                راه‌اندازی آسان
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                تنها در چند دقیقه سرویس خود را متصل کنید؛ بدون تنظیمات پیچیده شبکه.
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Our Solutions -->
<MudText Typo="Typo.h3" Align="Align.Center" Class="mt-16 mb-8 font-weight-bold">هر آنچه برای آنلاین کردن سرویس‌های خود نیاز دارید</MudText>
<MudGrid Spacing="4" Class="mb-16">
    <!-- Reverse Proxy Card -->
    <MudItem xs="12" md="6">
        <MudCard Class="rounded-lg" Outlined>
            <MudCardHeader>
                <MudText Typo="Typo.h4" Class="font-weight-bold">Reverse Proxy</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-4">بدون IP ثابت، Port Forwarding یا تنظیمات پیچیده روتر، سرویس‌های داخل شبکه خود را تنها با یک دامنه یا پورت اختصاصی از هر نقطه اینترنت در دسترس قرار دهید.</MudText>
                <MudList T="object" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                        اتصال امن
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                        پشتیبانی از TCP , UDP , HTTP
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                        سرعت بالا
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                        آپتایم 99.9%
                    </MudListItem>
                </MudList>
                <MudDivider Class="mb-2" />
                <MudText Typo="Typo.caption">مناسب برای: Home Server • NAS • دوربین مدار بسته • Remote Desktop • Game Server</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="wiki/reverse-proxy" Class="mt-2">اطلاعات بیشتر</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- DDNS Card -->
    <MudItem xs="12" md="6">
        <MudCard Class="rounded-lg" Outlined>
            <MudCardHeader>
                <MudText Typo="Typo.h4" Class="font-weight-bold">DDNS پویا</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-4">اگر IP اینترنت شما دائماً تغییر می‌کند، DNSLab همیشه دامنه شما را به آخرین IP متصل نگه می‌دارد؛ بدون نیاز به IP ثابت.</MudText>
                <MudList T="object" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                        بروزرسانی خودکار IP
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                        استفاده از رمزنگاری DNSSEC
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                       سازگاری گسترده (روتر، Mikrotik، Raspberry Pi و اسکریپت)
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">
                        دامنه و زیردامنه اختصاصی
                    </MudListItem>
                </MudList>
                <MudDivider Class="mb-2" />
                <MudText Typo="Typo.caption">مناسب برای: روتر • سرور خانگی • VPS • Docker • Raspberry Pi</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="wiki/dynamic-dns" Class="mt-2">اطلاعات بیشتر</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<!-- Stats Cards with Glassmorphism Effect -->
<MudText Typo="Typo.h3" Align="Align.Center" Class="mt-16 mb-8 font-weight-bold">مورد اعتماد هزاران کاربر</MudText>
<MudGrid Spacing="3" Justify="Justify.Center" Class="my-12">
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@Icons.Material.Filled.People" Class="my-2" Style="font-size: 3rem" />
            <MudText Typo="Typo.subtitle1" Class="mt-2">کاربران فعال</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@((_AllUsersCount ?? 0).Separate3Digits())</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@Icons.Material.Filled.Dns" Class="my-2" Style="font-size: 3rem" />
            <MudText Typo="Typo.subtitle1" Class="mt-2">هاست‌های فعال</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@((_AllDDNSsCount ?? 0).Separate3Digits())</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Class="my-2" Style="font-size: 3rem" />
            <MudText Typo="Typo.subtitle1" Class="mt-2">تغییرات IP روزانه</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@((_AllTodayChangesCount ?? 0).Separate3Digits())</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Footer -->
<MudDivider />
<MudGrid Class="py-8 mt-8">
    <MudItem xs="12" md="6">
        <MudStack Class="mt-5" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Spacing="1">
            <MudText Align="Align.Center" Typo="Typo.body2">تمامی حقوق سایت برای دی‌ان‌اس لب محفوظ است ©</MudText>
            <MudText Align="Align.Center" Color="Color.Primary">
                <MudLink Href="@AllRoutes.Terms" Underline="Underline.None" Color="Color.Inherit" Typo="Typo.body2" Class="mr-4">شرایط و ضوابط استفاده</MudLink>
            </MudText>
        </MudStack>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudStack Row Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="4">
            <MudImage Src="images/enamad.png" Height="90" />
            <MudImage Src="images/logo.png" Height="90" />
        </MudStack>
    </MudItem>
    <MudItem xs="12">
        <MudText Typo="Typo.body2" Align="Align.Center">
            ساخته شده برای مردم ایران
            <MudFlexBreak />
            ما باور داریم تکنولوژی باید در دسترس همه‌ی ایرانی‌ها باشه؛ سریع، امن و بدون وابستگی.
        </MudText>
    </MudItem>
</MudGrid>