@attribute [Route(AllRoutes.TcpReverseProxy)]
@attribute [Authorize]
<SeoProvider Title="TCP Tunnel" />

<MudText Typo="Typo.h1" Align="Align.Center">تونل TCP</MudText>
<MudText Class="mt-5" Align="Align.Center">
    سرویس‌های TCP مانند SSH، RDP، FTP، دیتابیس‌ها و سایر پروتکل‌های مبتنی بر TCP را بدون Port Forwarding و تنظیمات پیچیده شبکه از طریق اینترنت در دسترس قرار دهید.
</MudText>
<MudText Class="mb-10" Align="Align.Center">
    مناسب برای: SSH، RDP، FTP، SQL Server، MySQL و سایر سرویس‌های TCP
</MudText>

<MudPaper Class="mt-5 pa-10" Outlined>

    <MudText Typo="Typo.h4" Class="mb-4">
        موارد استفاده
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 fill-height" Outlined>
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Large" />
                <MudText Typo="Typo.h6">SSH</MudText>
                <MudText Typo="Typo.body2">
                    دسترسی امن به سرور و تجهیزات شبکه
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 fill-height" Outlined>
                <MudIcon Icon="@Icons.Material.Filled.DesktopWindows" Size="Size.Large" />
                <MudText Typo="Typo.h6">RDP</MudText>
                <MudText Typo="Typo.body2">
                    اتصال Remote Desktop از طریق اینترنت
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 fill-height" Outlined>
                <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Large" />
                <MudText Typo="Typo.h6">دیتابیس</MudText>
                <MudText Typo="Typo.body2">
                    دسترسی به SQL Server، MySQL و PostgreSQL
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h4" Class="my-2">
        شروع سریع
    </MudText>

    <MudText Class="mb-4">
        اگر سرویس TCP شما روی پورت 80 در حال اجرا است، دستور زیر را اجرا کنید:
    </MudText>

    <CodeSnippet Language="bash" Code="tcp 80" />

    <MudAlert Severity="Severity.Success"
              ContentAlignment="HorizontalAlignment.Start"
              Class="mt-4">
        پس از اجرا، DNSLab یک آدرس TCP عمومی در اختیار شما قرار می‌دهد.
    </MudAlert>

    <MudText Typo="Typo.h4" Class="my-2">
        نمونه خروجی
    </MudText>

    <CodeSnippet Language="text"
                 Code="tcp.dnslab.ir:12345" />

    <MudAlert Severity="Severity.Success"
              ContentAlignment="HorizontalAlignment.Start"
              Class="mt-4">
        کاربران می‌توانند از طریق این آدرس و پورت به سرویس شما متصل شوند.
    </MudAlert>

    <MudText Typo="Typo.h4" Class="my-2">
        آدرس و پورت رزرو شده
    </MudText>

    <MudText Class="mb-2">
        اگر اشتراک فعال دارید می‌توانید یک آدرس و پورت ثابت رزرو کنید.
    </MudText>

    <CodeSnippet Language="bash"
                 Code="tcp 80 tcp.dnslab.ir:5001" />

    <MudAlert Severity="Severity.Info"
              ContentAlignment="HorizontalAlignment.Start"
              Class="mt-4">
        آدرس tcp.dnslab.ir:5001 برای شما رزرو خواهد شد.
    </MudAlert>

</MudPaper>