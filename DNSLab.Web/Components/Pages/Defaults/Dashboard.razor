@attribute [Route(AllRoutes.Dashboard)]
@attribute [Authorize]

<SeoProvider Title="داشبورد" />

<MudContainer MaxWidth="MaxWidth.False">
    <MudStack Spacing="1" Class="mb-8">
        <MudText Typo="Typo.h3">داشبورد</MudText>
        <MudText Typo="Typo.body1">نمای کلی از دامنه‌ها، رکوردها و هاست‌نیم‌های شما</MudText>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Outlined Class="pa-5 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Language" />
                    </MudAvatar>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@ZoneCount</MudText>
                </MudStack>
                <MudText Class="mt-4" Typo="Typo.h6">دامنه‌ها</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Outlined Class="pa-5 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudAvatar Color="Color.Info" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Dns" />
                    </MudAvatar>
                    <MudText Typo="Typo.h4" Color="Color.Info">@RecordsCount</MudText>
                </MudStack>
                <MudText Class="mt-4" Typo="Typo.h6">رکوردها</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Outlined Class="pa-5 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudAvatar Color="Color.Success" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Router" />
                    </MudAvatar>
                    <MudText Typo="Typo.h4" Color="Color.Success">@DDNSsCount</MudText>
                </MudStack>
                <MudText Class="mt-4" Typo="Typo.h6">هاست‌نیم‌ها</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Outlined Class="pa-5 rounded-lg">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudAvatar Color="Color.Warning" Variant="Variant.Filled">
                        <MudIcon Icon="@DNSLabIcons.Tunnels" />
                    </MudAvatar>
                    <MudText Typo="Typo.h4" Color="Color.Warning">@OnlineTunnelsCount</MudText>
                </MudStack>
                <MudText Class="mt-4" Typo="Typo.h6">تعداد تونل های فعال</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="my-4">
        دسترسی سریع
    </MudText>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined Class="pa-5 rounded-lg cursor-pointer" @onclick="@(() => _NavigationManager.NavigateTo(AllRoutes.DDNSHostNames))">
                <MudAvatar Size="Size.Large" Color="Color.Primary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.AddLink" />
                </MudAvatar>
                <MudText Typo="Typo.h6" Class="mt-4">ایجاد هاست‌نیم</MudText>
                <MudText Typo="Typo.body2" Color="Color.Primary">ثبت یک هاست‌نیم جدید برای اتصال به سرویس‌های خود</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined Class="pa-5 rounded-lg cursor-pointer" @onclick="@(() => _NavigationManager.NavigateTo(AllRoutes.SetupAndInstallation))">
                <MudAvatar Size="Size.Large" Color="Color.Success" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.Terminal" />
                </MudAvatar>
                <MudText Typo="Typo.h6" Class="mt-4">راه‌اندازی Tunnel</MudText>
                <MudText Typo="Typo.body2" Color="Color.Primary">دانلود DNSLab CLI و اتصال اولین دستگاه</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined Class="pa-5 rounded-lg cursor-pointer" @onclick="@(() => _NavigationManager.NavigateTo(AllRoutes.MyWallet))">
                <MudAvatar Size="Size.Large" Color="Color.Warning" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                </MudAvatar>
                <MudText Typo="Typo.h6" Class="mt-4">کیف پول</MudText>
                <MudText Typo="Typo.body2" Color="Color.Primary">افزایش موجودی برای خرید و تمدید سرویس‌ها</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined Class="pa-5 rounded-lg cursor-pointer" @onclick="@(() => _NavigationManager.NavigateTo(AllRoutes.Plans))">
                <MudAvatar Size="Size.Large" Color="Color.Tertiary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" />
                </MudAvatar>
                <MudText Typo="Typo.h6" Class="mt-4">ارتقای اشتراک</MudText>
                <MudText Typo="Typo.body2" Color="Color.Primary">مشاهده پلن‌ها و دسترسی به امکانات بیشتر</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>