@attribute [Route(AllRoutes.UdpReverseProxy)]
@attribute [Authorize]
<SeoProvider Title="UDP Tunnel" />

<MudText Typo="Typo.h1" Align="Align.Center">تونل UDP</MudText>
<MudText Class="mt-5" Align="Align.Center">
    سرویس‌های UDP مانند DNS، بازی‌های آنلاین، تماس صوتی و تصویری و سایر پروتکل‌های مبتنی بر UDP را بدون Port Forwarding و تنظیمات پیچیده شبکه از طریق اینترنت در دسترس قرار دهید.
</MudText>
<MudText Class="mb-10" Align="Align.Center">
    مناسب برای: DNS، بازی‌های آنلاین، VoIP، استریم رسانه و سایر سرویس‌های UDP
</MudText>

<MudPaper Class="mt-5 pa-10" Outlined>

    <MudText Typo="Typo.h4" Class="mb-4">
        موارد استفاده
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 fill-height" Outlined>
                <MudIcon Icon="@Icons.Material.Filled.Dns" Size="Size.Large" />
                <MudText Typo="Typo.h6">DNS</MudText>
                <MudText Typo="Typo.body2">
                    انتشار و تست سرویس‌های DNS
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 fill-height" Outlined>
                <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Size="Size.Large" />
                <MudText Typo="Typo.h6">بازی آنلاین</MudText>
                <MudText Typo="Typo.body2">
                    دسترسی به سرورهای بازی مبتنی بر UDP
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 fill-height" Outlined>
                <MudIcon Icon="@Icons.Material.Filled.Call" Size="Size.Large" />
                <MudText Typo="Typo.h6">تماس صوتی و تصویری</MudText>
                <MudText Typo="Typo.body2">
                    سرویس‌های VoIP و ارتباطات بلادرنگ
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h4" Class="my-2">
        شروع سریع
    </MudText>

    <MudText Class="mb-4">
        اگر سرویس UDP شما روی پورت 53 در حال اجرا است، دستور زیر را اجرا کنید:
    </MudText>

    <CodeSnippet Language="bash" Code="udp 53" />

    <MudAlert Severity="Severity.Success"
              ContentAlignment="HorizontalAlignment.Start"
              Class="mt-4">
        پس از اجرا، DNSLab یک آدرس UDP عمومی در اختیار شما قرار می‌دهد.
    </MudAlert>

    <MudText Typo="Typo.h4" Class="my-2">
        نمونه خروجی
    </MudText>

    <CodeSnippet Language="text"
                 Code="udp.dnslab.ir:12345" />

    <MudAlert Severity="Severity.Success"
              ContentAlignment="HorizontalAlignment.Start"
              Class="mt-4">
        کاربران می‌توانند از طریق این آدرس و پورت به سرویس شما متصل شوند.
    </MudAlert>

    <MudText Typo="Typo.h4" Class="my-2">
        آدرس و پورت رزرو شده
    </MudText>

    <MudText Class="mb-2">
        اگر اشتراک فعال دارید می‌توانید یک آدرس و پورت ثابت رزرو کنید.
    </MudText>

    <CodeSnippet Language="bash"
                 Code="udp 53 udp.dnslab.ir:5001" />

    <MudAlert Severity="Severity.Info"
              ContentAlignment="HorizontalAlignment.Start"
              Class="mt-4">
        آدرس udp.dnslab.ir:5001 برای شما رزرو خواهد شد.
    </MudAlert>

</MudPaper>