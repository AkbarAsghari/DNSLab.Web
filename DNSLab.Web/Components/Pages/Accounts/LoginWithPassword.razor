@attribute [Route(AllRoutes.LoginWithPassword)]
<SeoProvider Title="صفحه ورود" Meta_Description="ورود به سیستم سایت DNSLab" />

<MudText Typo="Typo.h1" Align="Align.Center">ورود</MudText>

<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pt-10">
    <MudGrid Justify="Justify.Center">
        <MudItem lg="5" md="6" sm="8" xs="12">
            <MudCard Elevation="0" Class="pa-5">
                <MudCardContent>
                    <EditForm Model="_AuthenticateDTO" Context="ctx">
                        <DataAnnotationsValidator />
                        <MudText Typo="Typo.caption">شماره موبایل، ایمیل و یا نام کاربری خود را وارد کنید.</MudText>
                        <MudTextField T="string" Placeholder="شماره موبایل، ایمیل و یا نام کاربری" Variant="Variant.Outlined" Class="my-2 dnslab-ltr" @bind-Value="_AuthenticateDTO.MobileOrEmailOrUsername" For="()=>_AuthenticateDTO.MobileOrEmailOrUsername"></MudTextField>
                        <MudStack Row Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption">رمز عبور</MudText>
                            <MudLink Underline="Underline.None" Href="@AllRoutes.ForgetPassword">
                                <MudText Typo="Typo.caption" Color="Color.Error">رمزت رو فراموش کردی ؟</MudText>
                            </MudLink>
                        </MudStack>
                        <MudTextField T="string" InputType="InputType.Password" Placeholder="رمز عبور" Variant="Variant.Outlined" Class="mt-2 mb-4 dnslab-ltr" @bind-Value="_AuthenticateDTO.Password" For="()=>_AuthenticateDTO.Password"></MudTextField>
                        <BaseButton Color="Color.Primary" EditContext="ctx" OnClick="Authenticate" ButtonType="ButtonType.Submit" Variant="Variant.Filled" FullWidth>ورود</BaseButton>
                        <BaseButton Href="@($"{AllRoutes.Login}{(String.IsNullOrEmpty(RedirectTo) ? String.Empty : $"?RedirectTo={RedirectTo}")}")" Variant="Variant.Text" FullWidth Class="mt-2">ورود با رمز یکبار مصرف</BaseButton>
                    </EditForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudStack>