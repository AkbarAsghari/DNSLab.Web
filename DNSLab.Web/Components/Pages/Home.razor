@page "/"

<SeoProvider Title="DNSLab | DDNS و Reverse Proxy برای سرورهای خانگی"
             Meta_Description="بدون IP ثابت، سرور خانگی، دوربین امنیتی یا پروژه خود را در ۵ دقیقه آنلاین کنید. سرویس DDNS و Reverse Proxy امن و سریع" />

<!-- Hero Section with Gradient -->
<MudText Typo="Typo.h2" Align="Align.Center" Class="mt-8 mb-3 font-weight-bold">
    هر سرویس محلی را در کمتر از ۱ دقیقه روی اینترنت منتشر کنید
</MudText>
<MudText Typo="Typo.h5" Align="Align.Center" Class="mb-8 mt-4">بدون IP ثابت، بدون Port Forwarding و بدون دردسر NAT</MudText>

<!-- Stats Cards with Glassmorphism Effect -->
<MudText Typo="Typo.h3" Align="Align.Center" Class="mt-16 mb-8 font-weight-bold">مورد اعتماد هزاران کاربر</MudText>
<MudGrid Spacing="3" Justify="Justify.Center" Class="my-12">
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@Icons.Material.Filled.People" Class="my-2" Style="font-size: 3rem" />
            <MudText Typo="Typo.subtitle1" Class="mt-2">کاربران فعال</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@((_AllUsersCount ?? 0).Separate3Digits())</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@Icons.Material.Filled.Dns" Class="my-2" Style="font-size: 3rem" />
            <MudText Typo="Typo.subtitle1" Class="mt-2">هاست‌های فعال</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@((_AllDDNSsCount ?? 0).Separate3Digits())</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Class="my-2" Style="font-size: 3rem" />
            <MudText Typo="Typo.subtitle1" Class="mt-2">تغییرات IP روزانه</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@((_AllTodayChangesCount ?? 0).Separate3Digits())</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h3" Align="Align.Center" Class="mt-16 mb-8 font-weight-bold">راه‌حل‌های ما برای نیازهای شما</MudText>
<MudGrid Spacing="4" Class="mb-16">
    <!-- Reverse Proxy Card -->
    <MudItem xs="12" md="6">
        <MudCard Class="rounded-lg" Outlined>
            <MudCardHeader>
                <MudText Typo="Typo.h4" Class="font-weight-bold">Reverse Proxy</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-4">ببدون درگیر شدن با تنظیمات پیچیده روتر یا محدودیت‌های NAT، هر سرویس داخل شبکه‌ات را تنها با یک زیردامنه یا پورت اختصاصی به اینترنت متصل کن — سریع، امن و آماده استفاده، در چند ثانیه.</MudText>
                <MudGrid Spacing="2" Class="mb-4">
                    <MudItem xs="4">
                        <MudPaper Class="d-flex flex-column align-center pa-2" Elevation="0">
                            <MudIcon Icon="@DNSLabIcons.Security" Style="width: 60px; height: 60px;" />
                            <MudText Typo="Typo.body2" Class="mt-2">اتصال امن</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex flex-column align-center pa-2" Elevation="0">
                            <MudIcon Icon="@DNSLabIcons.Speed" Style="width: 60px; height: 60px;" />
                            <MudText Typo="Typo.body2" Class="mt-2">سرعت بالا</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex flex-column align-center pa-2" Elevation="0">
                            <MudIcon Icon="@DNSLabIcons.Protocols" Style="width: 60px; height: 60px;" />
                            <MudText Typo="Typo.body2" Class="mt-2">HTTP - TCP - UDP</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Href="wiki/reverse-proxy" Class="mt-2">اطلاعات بیشتر</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- DDNS Card -->
    <MudItem xs="12" md="6">
        <MudCard Class="rounded-lg" Outlined>
            <MudCardHeader>
                <MudText Typo="Typo.h4" Class="font-weight-bold">DDNS پویا</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-4">DDNS به دستگاهی با آدرس IP متغیر اجازه می‌دهد تا همیشه با یک نام دامنه ثابت در دسترس باشد؛ بدون نیاز به IP ثابت و هزینه اضافی.</MudText>
                <MudGrid Spacing="2" Class="mb-4">
                    <MudItem xs="6" md="3">
                        <MudPaper Class="d-flex flex-column align-center pa-2" Elevation="0">
                            <MudImage Src="images/icons/router.svg" Style="background-color: floralwhite; border-radius: 8px; width: 60px;" />
                            <MudText Typo="Typo.body2" Class="mt-2">روتر</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudPaper Class="d-flex flex-column align-center pa-2" Elevation="0">
                            <MudImage Src="images/icons/mikrotik.svg" Style="background-color: floralwhite; border-radius: 8px; width: 60px;" />
                            <MudText Typo="Typo.body2" Class="mt-2">میکروتیک</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudPaper Class="d-flex flex-column align-center pa-2" Elevation="0">
                            <MudImage Src="images/icons/raspberry.svg" Style="background-color: floralwhite; border-radius: 8px; width: 60px;" />
                            <MudText Typo="Typo.body2" Class="mt-2">رزبری‌پای</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudPaper Class="d-flex flex-column align-center pa-2" Elevation="0">
                            <MudImage Src="images/icons/script.svg" Style="background-color: floralwhite; border-radius: 8px; width: 60px;" />
                            <MudText Typo="Typo.body2" Class="mt-2">اسکریپت</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Href="wiki/dynamic-dns" Class="mt-2">اطلاعات بیشتر</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<!-- Why Choose Us -->
<MudText Typo="Typo.h3" Align="Align.Center" Class="mt-16 mb-8 font-weight-bold">چرا کاربران ما DNSLab را انتخاب می‌کنند؟</MudText>
<MudGrid Spacing="6" Justify="Justify.Center" Class="mb-16">
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@DNSLabIcons.Lan" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">دسترسی به شبکه خانگی</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">از هرجا به دستگاه‌های خانه متصل شوید</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@DNSLabIcons.Game" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">سرورهای بازی</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">ماینکرفت و دیگر سرورهای بازی را میزبانی کنید</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-lg" Outlined>
            <MudIcon Icon="@DNSLabIcons.SecurityCamera" Style="font-size: 3.5rem" />
            <MudText Typo="Typo.h5" Class="mt-3 font-weight-bold">دوربین مدار بسته</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">با هر اینترنتی به دوربین خود دسترسی داشته باشید</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- CTA -->
<MudText Typo="Typo.h3" Align="Align.Center" Class="mt-16 mb-8 font-weight-bold">آماده شروع هستید؟</MudText>
<MudPaper Class="pa-10 my-12" Outlined>
    <MudText Align="Align.Center" Class="mb-4">
        همین الان اولین سرویس خود را آنلاین کنید
    </MudText>

    <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
        <BaseButton Variant="Variant.Filled"
                    Color="Color.Primary"
                    Href="@AllRoutes.SetupAndInstallation">
            دانلود DNSLab CLI 🚀
        </BaseButton>
    </MudStack>

</MudPaper>

<!-- Footer -->
<MudDivider />
<MudGrid Class="py-8 mt-8">
    <MudItem xs="12" md="6">
        <MudStack Class="mt-5" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Spacing="1">
            <MudText Align="Align.Center" Typo="Typo.body2">تمامی حقوق سایت برای دی‌ان‌اس لب محفوظ است ©</MudText>
            <MudText Align="Align.Center" Color="Color.Primary">
                <MudLink Href="@AllRoutes.Terms" Underline="Underline.None" Color="Color.Inherit" Typo="Typo.body2" Class="mr-4">شرایط و ضوابط استفاده</MudLink>
            </MudText>
        </MudStack>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudStack Row Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="4">
            <MudImage Src="images/enamad.png" Height="90" />
            <MudImage Src="images/logo.png" Height="90" />
        </MudStack>
    </MudItem>
    <MudItem xs="12">
        <MudText Typo="Typo.body2" Align="Align.Center">
            ساخته شده برای مردم ایران
            <MudFlexBreak />
            ما باور داریم تکنولوژی باید در دسترس همه‌ی ایرانی‌ها باشه؛ سریع، امن و بدون وابستگی.
        </MudText>
    </MudItem>
</MudGrid>