@attribute [Route(AllRoutes.Login)]
<SeoProvider Title="ثبت نام / ورود" Meta_Description="ثبت نام / ورود سایت DNSLab" />

<MudText Typo="Typo.h1" Align="Align.Center">
    ورود/ثبت نام
</MudText>

<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pt-10">
    <MudGrid Justify="Justify.Center">
        <MudItem lg="5" md="6" sm="8" xs="12">
            <MudCard Elevation="0" Class="pa-5">
                <MudCardContent>
                    @if (String.IsNullOrEmpty(_Token))
                    {
                        <MudText Typo="Typo.caption">شماره موبایل خود را وارد کنید</MudText>
                        <MudTextField T="string" Placeholder="شماره موبایل" Variant="Variant.Outlined" Class="my-2 dnslab-ltr" @bind-Value="_Mobile"></MudTextField>
                        <BaseButton Color="Color.Primary" Class="mt-2" ButtonType="ButtonType.Submit" OnClick="RegisterUser" Variant="Variant.Filled" FullWidth>ارسال کد</BaseButton>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption">
                            کد تایید ارسال شده به شماره @_Mobile را وارد کنید.
                        </MudText>
                        <MudTextField T="string" Placeholder="***********" Variant="Variant.Outlined" Class="my-2 dnslab-ltr" @bind-Value="_Otp"></MudTextField>
                        <MudStack Row Spacing="1" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudButton Size="Size.Small" EndIcon="@DNSLabIcons.Edit" OnClick="ChangeMobile">ویرایش شماره موبایل</MudButton>
                            <Timer ResendOtpCallBack="ResendOtp" />
                        </MudStack>
                        <BaseButton Color="Color.Primary" Class="mt-2" ButtonType="ButtonType.Submit" OnClick="ConfirmOtp" Variant="Variant.Filled" FullWidth>ورود به پنل کاربری</BaseButton>

                    }
                    <BaseButton Href="@($"{AllRoutes.LoginWithPassword}{(String.IsNullOrEmpty(RedirectTo) ? String.Empty : $"?RedirectTo={RedirectTo}")}")" Variant="Variant.Text" FullWidth Class="mt-2">ورود با رمز عبور</BaseButton>

                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudStack>